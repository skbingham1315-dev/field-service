# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fsp_user:fsp_password@localhost:5432/field_service_platform

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars-2

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com — free tier 3,000 emails/month
# Leave as 'placeholder' to simulate emails in dev (logs to console)
RESEND_API_KEY=placeholder
# Must be a verified domain in Resend. Use 'FSP <noreply@yourdomain.com>' format.
EMAIL_FROM=FSP <noreply@yourdomain.com>

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Get credentials at https://console.twilio.com
# Leave TWILIO_ACCOUNT_SID as 'ACplaceholder' to simulate SMS in dev
TWILIO_ACCOUNT_SID=ACplaceholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_PHONE_NUMBER=+15550000000

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ── AWS S3 (photo uploads) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_REGION=us-east-1
AWS_S3_BUCKET=fsp-photos
