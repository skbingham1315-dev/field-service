{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@fsp/types": ["../../packages/types/src"],
      "@fsp/db": ["../../packages/db/src"]
    }
  },
  "ts-node": {
