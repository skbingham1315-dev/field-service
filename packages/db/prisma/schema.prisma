generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ServiceType {
  pool
  pest_control
  turf
  handyman
}

enum TenantPlan {
  starter
  professional
  enterprise
}

enum TenantStatus {
  trial
  active
  suspended
  cancelled
}

enum UserRole {
  owner
  admin
  dispatcher
  technician
  sales
  customer
}

enum UserStatus {
  active
  inactive
  invited
}

enum JobStatus {
  draft
  scheduled
  en_route
  in_progress
  completed
  cancelled
  on_hold
}

enum JobPriority {
  low
  normal
  high
  urgent
}

enum InvoiceStatus {
  draft
  sent
  viewed
  paid
  overdue
  void
}

enum PaymentMethod {
  stripe
  cash
  check
  ach
  other
}

enum RecurrenceFrequency {
  daily
  weekly
  biweekly
  monthly
  custom
}

enum PhotoType {
  before
  after
  issue
  other
}

// ─── Tenant ──────────────────────────────────────────────────────────────────

model Tenant {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String       @unique
  serviceTypes         ServiceType[]
  plan                 TenantPlan   @default(starter)
  status               TenantStatus @default(trial)
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?      @unique
  twilioPhoneNumber    String?
  timezone             String       @default("America/New_York")
  currency             String       @default("USD")
  taxRate              Decimal      @default(0) @db.Decimal(5, 4)
  settings             Json         @default("{}")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  users            User[]
  customers        Customer[]
  jobs             Job[]
  invoices         Invoice[]
  serviceTemplates ServiceTemplate[]
  salesActivities  SalesActivity[]
  salesGoal        SalesGoal?
  timeEntries      TimeEntry[]
  payrollRuns      PayrollRun[]
  contacts         Contact[]
  crmJobs          CRMJob[]
  subcontractors   Subcontractor[]
  payComponents    PayComponent[]
  commissionEntries CommissionEntry[]
  salesTargets     SalesTarget[]
  portalConfig     PortalConfig?
  portalUsers      PortalUser[]
  portalWorkRequests PortalWorkRequest[]
  portalMessages   PortalMessage[]
  properties       Property[]
  pmTenants        PMTenant[]
  trainingResources    TrainingResource[]
  trainingProgress     TrainingUserProgress[]
  rolePlaySessions     RolePlaySession[]
  exerciseAnswers      TrainingExerciseAnswer[]

  @@map("tenants")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  tenantId          String
  email             String
  passwordHash      String
  firstName         String
  lastName          String
  phone             String?
  role              UserRole
  status            UserStatus @default(invited)
  avatarUrl         String?
  timezone          String?
  inviteToken       String?    @unique
  inviteExpiresAt   DateTime?
  lastLoginAt       DateTime?
  refreshTokenHash  String?
  skills            String[]
  licenseNumber     String?
  vehicleInfo       Json?
  isAvailable       Boolean    @default(false)
  serviceRadius     Float?
  payRate           Float?
  payType           String?    @default("hourly")
  employmentType    String?    // w2 | contractor_1099 | owner_partner
  territory         String?
  startDate         DateTime?
  showEarnings      Boolean    @default(false)
  customPermissions Json?
  lastLat           Float?
  lastLng           Float?
  lastLocationAt    DateTime?
  secondaryRoles      String[]   @default([])
  passwordResetToken  String?    @unique
  passwordResetExpiry DateTime?
  createdAt           DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedJobs        Job[]         @relation("TechnicianJobs")
  createdJobs         Job[]         @relation("CreatedByJobs")
  jobAssignments      JobTechnician[]
  jobNotes            JobNote[]
  jobPhotos           JobPhoto[]
  technicianLocations TechnicianLocation[]
  salesActivities     SalesActivity[]
  reviewsReceived     JobReview[]   @relation("TechnicianReviews")
  timeEntries         TimeEntry[]
  payrollEntries      PayrollEntry[]
  payrollRuns         PayrollRun[]  @relation("PayrollCreatedBy")
  payComponents       PayComponent[]
  commissionEntries   CommissionEntry[]
  salesTargets        SalesTarget[]
  primarySalesJobs    CRMJob[]      @relation("PrimarySales")
  secondarySalesJobs  CRMJob[]      @relation("SecondarySales")
  pmJobs              CRMJob[]      @relation("PMJobs")
  contractorBadges    ContractorBadge[]
  trainingCreated     TrainingResource[]  @relation("TrainingCreated")
  trainingProgress    TrainingUserProgress?
  rolePlaySessions    RolePlaySession[]
  exerciseAnswers     TrainingExerciseAnswer[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

// ─── Customer ────────────────────────────────────────────────────────────────

model Customer {
  id               String         @id @default(cuid())
  tenantId         String
  firstName        String
  lastName         String
  email            String?
  phone            String?
  status           String         @default("active")
  stripeCustomerId String?
  notes            String?
  tags             String[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceAddresses ServiceAddress[]
  jobs             Job[]
  invoices         Invoice[]
  smsMessages      SmsMessage[]
  portalUsers      PortalUser[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@map("customers")
}

model ServiceAddress {
  id                  String   @id @default(cuid())
  customerId          String
  label               String?
  street              String
  city                String
  state               String
  zip                 String
  country             String   @default("US")
  lat                 Float?
  lng                 Float?
  accessInstructions  String?
  isPrimary           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs     Job[]

  @@index([customerId])
  @@map("service_addresses")
}

// ─── Job ─────────────────────────────────────────────────────────────────────

model Job {
  id                String      @id @default(cuid())
  tenantId          String
  customerId        String
  serviceAddressId  String
  technicianId      String?
  createdById       String?
  serviceType       ServiceType
  title             String
  description       String?
  status            JobStatus   @default(draft)
  priority          JobPriority @default(normal)
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  actualStart       DateTime?
  actualEnd         DateTime?
  estimatedDuration Int?        // minutes
  customFields      Json?
  parentJobId       String?
  invoiceId         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       Customer       @relation(fields: [customerId], references: [id])
  serviceAddress ServiceAddress @relation(fields: [serviceAddressId], references: [id])
  technician     User?          @relation("TechnicianJobs", fields: [technicianId], references: [id])
  createdBy      User?          @relation("CreatedByJobs", fields: [createdById], references: [id])
  parentJob      Job?           @relation("RecurringJobs", fields: [parentJobId], references: [id])
  childJobs      Job[]          @relation("RecurringJobs")
  lineItems      JobLineItem[]
  photos         JobPhoto[]
  notes          JobNote[]
  recurrence     RecurrenceRule?
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id])
  review              JobReview?
  timeEntries         TimeEntry[]
  assignedTechnicians JobTechnician[]

  @@index([tenantId, status])
  @@index([tenantId, technicianId])
  @@index([tenantId, scheduledStart])
  @@index([customerId])
  @@map("jobs")
}

model JobTechnician {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  createdAt DateTime @default(now())

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@map("job_technicians")
}

model JobLineItem {
  id          String  @id @default(cuid())
  jobId       String
  description String
  quantity    Float
  unitPrice   Int     // cents
  taxable     Boolean @default(true)
  serviceCode String?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_line_items")
}

model JobPhoto {
  id           String    @id @default(cuid())
  jobId        String
  uploadedById String
  s3Key        String
  url          String
  caption      String?
  type         PhotoType @default(other)
  takenAt      DateTime  @default(now())
  createdAt    DateTime  @default(now())

  job        Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([jobId])
  @@map("job_photos")
}

model JobNote {
  id         String   @id @default(cuid())
  jobId      String
  authorId   String
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([jobId])
  @@map("job_notes")
}

model RecurrenceRule {
  id          String              @id @default(cuid())
  jobId       String              @unique
  frequency   RecurrenceFrequency
  interval    Int                 @default(1)
  daysOfWeek  Int[]
  dayOfMonth  Int?
  endDate     DateTime?
  occurrences Int?
  createdAt   DateTime            @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("recurrence_rules")
}

// ─── Invoice & Payment ────────────────────────────────────────────────────────

model Invoice {
  id                     String        @id @default(cuid())
  tenantId               String
  customerId             String
  invoiceNumber          String
  status                 InvoiceStatus @default(draft)
  subtotal               Int           // cents
  taxAmount              Int           // cents
  discountAmount         Int           @default(0)
  total                  Int           // cents
  amountPaid             Int           @default(0)
  amountDue              Int           // cents
  dueDate                DateTime?
  issuedAt               DateTime?
  paidAt                 DateTime?
  stripePaymentIntentId  String?
  notes                  String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer           @relation(fields: [customerId], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]
  jobs      Job[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([customerId])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Int     // cents
  total       Int     // cents
  taxable     Boolean @default(true)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id                     String        @id @default(cuid())
  tenantId               String
  invoiceId              String
  amount                 Int           // cents
  method                 PaymentMethod
  stripePaymentIntentId  String?
  stripeChargeId         String?
  notes                  String?
  paidAt                 DateTime
  createdAt              DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

// ─── Service Templates ────────────────────────────────────────────────────────

model ServiceTemplate {
  id          String      @id @default(cuid())
  tenantId    String
  serviceType ServiceType
  name        String
  description String?
  duration    Int         // minutes
  lineItems   Json        // default line items
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("service_templates")
}

// ─── Sales Activity ──────────────────────────────────────────────────────────

model SalesActivity {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String
  date            DateTime @db.Date
  doorsKnocked    Int      @default(0)
  peopleContacted Int      @default(0)
  estimatesGiven  Int      @default(0)
  leadsAdded      Int      @default(0)
  jobsScheduled   Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([tenantId, date])
  @@map("sales_activities")
}

model SalesGoal {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  doorsKnocked    Int      @default(20)
  peopleContacted Int      @default(10)
  estimatesGiven  Int      @default(5)
  leadsAdded      Int      @default(3)
  jobsScheduled   Int      @default(2)
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sales_goals")
}

// ─── Job Review ───────────────────────────────────────────────────────────────

model JobReview {
  id              String    @id @default(cuid())
  tenantId        String
  jobId           String    @unique
  customerId      String
  technicianId    String?
  rating          Int?      // overall 1-5
  qualityScore    Int?      // 1-5
  punctualityScore Int?     // 1-5
  communicationScore Int?   // 1-5
  valueScore      Int?      // 1-5
  comment         String?
  reviewerName    String?
  isVerified      Boolean   @default(false)
  isPublic        Boolean   @default(true)
  isFlagged       Boolean   @default(false)
  reviewToken     String    @unique @default(cuid())
  submittedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  technician      User?     @relation("TechnicianReviews", fields: [technicianId], references: [id])
  response        ReviewResponse?

  @@index([tenantId])
  @@index([technicianId])
  @@map("job_reviews")
}

model ReviewResponse {
  id          String    @id @default(cuid())
  reviewId    String    @unique
  body        String
  respondedBy String?
  createdAt   DateTime  @default(now())

  review      JobReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_responses")
}

model ContractorBadge {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  badgeType   String   // top_rated | fast_responder | perfect_score | veteran | most_reviewed
  awardedAt   DateTime @default(now())
  expiresAt   DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("contractor_badges")
}

// ─── SMS Messages ─────────────────────────────────────────────────────────────

model SmsMessage {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  direction  String   // 'outbound' | 'inbound'
  from       String
  to         String
  body       String
  twilioSid  String?  @unique
  status     String   @default("sent") // sent | delivered | failed | received
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([tenantId])
  @@map("sms_messages")
}

// ─── Technician Location (time-series) ───────────────────────────────────────

model TechnicianLocation {
  id           String   @id @default(cuid())
  technicianId String
  lat          Float
  lng          Float
  heading      Float?
  speed        Float?
  recordedAt   DateTime @default(now())

  technician User @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId, recordedAt])
  @@map("technician_locations")
}

// ─── Time Tracking ────────────────────────────────────────────────────────────

enum TimeEntryStatus {
  pending
  approved
  paid
}

model TimeEntry {
  id          String          @id @default(cuid())
  tenantId    String
  userId      String
  jobId       String?
  date        DateTime        @db.Date
  clockIn     DateTime?
  clockOut    DateTime?
  clockInLat  Float?
  clockInLng  Float?
  hoursWorked Float           @default(0)
  notes       String?
  status      TimeEntryStatus @default(pending)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([tenantId, date])
  @@index([userId, date])
  @@map("time_entries")
}

// ─── CRM — Contacts ──────────────────────────────────────────────────────────

enum ContactType {
  business
  individual
}

enum ContactStatus {
  prospect
  contacted
  follow_up
  try_later
  scheduled
  new_client
  active_client
  on_hold
  do_not_contact
}

enum LeadSource {
  natural_contact
  door_to_door
  business_referral
  cold_outreach
  social_media
  online_ad
  google_search
  past_customer
  other
}

enum ActivityEntryType {
  call
  email
  visit
  text
  estimate_sent
  job_completed
  note
  status_change
  follow_up_set
}

enum CRMJobStatus {
  estimate_pending
  estimate_sent
  approved
  scheduled
  in_progress
  completed
  invoiced
  paid
  on_hold
  cancelled
  warranty_callback
}

enum JobExecutionType {
  in_house
  subcontracted
}

model Contact {
  id              String        @id @default(cuid())
  tenantId        String
  type            ContactType   @default(individual)

  // Business fields
  businessName    String?
  contactPerson   String?
  website         String?
  industry        String?

  // Shared / individual
  fullName        String?
  howWeMet        String?

  phone           String
  email           String?
  address         String?
  city            String?
  state           String?
  zip             String?

  status          ContactStatus @default(prospect)
  leadSource      LeadSource
  leadSourceOther String?

  followUpDate    DateTime?
  notes           String?
  isArchived      Boolean       @default(false)

  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activities      ContactActivity[]
  crmJobs         CRMJob[]

  @@index([tenantId, status])
  @@index([tenantId, leadSource])
  @@index([tenantId, followUpDate])
  @@map("contacts")
}

model ContactActivity {
  id          String            @id @default(cuid())
  contactId   String
  type        ActivityEntryType
  note        String?
  createdBy   String
  createdAt   DateTime          @default(now())

  contact     Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_activities")
}

// ─── CRM — Jobs ───────────────────────────────────────────────────────────────

model CRMJob {
  id                  String           @id @default(cuid())
  tenantId            String
  jobNumber           String

  name                String
  contactId           String
  serviceAddress      String?
  serviceCity         String?
  serviceState        String?
  serviceZip          String?

  tradeCategory       String?
  status              CRMJobStatus     @default(estimate_pending)
  executionType       JobExecutionType @default(in_house)

  assignedToId        String?
  subcontractorId     String?

  estimatedStartDate  DateTime?
  completionDate      DateTime?

  estimatedValue      Decimal?         @db.Decimal(10, 2)
  actualInvoiceAmount Decimal?         @db.Decimal(10, 2)

  permitRequired      String?
  permitNumber        String?
  notes               String?

  // Sub payment calculator
  subPaymentType      String?
  subPaymentAmount    Decimal?         @db.Decimal(10, 2)
  subPaymentPercent   Decimal?         @db.Decimal(5, 2)
  materialsCost       Decimal?         @db.Decimal(10, 2)
  otherCosts          Decimal?         @db.Decimal(10, 2)
  targetMargin        Decimal?         @db.Decimal(5, 2) @default(25)

  // Team credit
  primarySalesId      String?
  primarySalesPct     Decimal?         @db.Decimal(5, 2) @default(100)
  secondarySalesId    String?
  secondarySalesPct   Decimal?         @db.Decimal(5, 2)
  pmId               String?
  commissionTriggered Boolean          @default(false)

  isArchived          Boolean          @default(false)
  createdById         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact             Contact          @relation(fields: [contactId], references: [id])
  subcontractor       Subcontractor?   @relation(fields: [subcontractorId], references: [id])
  primarySales        User?            @relation("PrimarySales", fields: [primarySalesId], references: [id])
  secondarySales      User?            @relation("SecondarySales", fields: [secondarySalesId], references: [id])
  pm                  User?            @relation("PMJobs", fields: [pmId], references: [id])
  activities          CRMJobActivity[]
  commissionEntries   CommissionEntry[]

  @@unique([tenantId, jobNumber])
  @@index([tenantId, status])
  @@index([contactId])
  @@map("crm_jobs")
}

model CRMJobActivity {
  id        String            @id @default(cuid())
  jobId     String
  type      ActivityEntryType
  note      String?
  createdBy String
  createdAt DateTime          @default(now())

  job       CRMJob            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("crm_job_activities")
}

// ─── Subcontractors ───────────────────────────────────────────────────────────

model Subcontractor {
  id                String    @id @default(cuid())
  tenantId          String
  name              String
  contactName       String?
  phone             String
  email             String?
  licenseNumber     String?
  insuranceExpDate  DateTime?
  tradeSpecialties  String[]
  defaultRateType   String?
  defaultPercentage Decimal?  @db.Decimal(5, 2)
  notes             String?
  reliabilityRating Int?
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  crmJobs           CRMJob[]

  @@index([tenantId])
  @@map("subcontractors")
}

// ─── Payroll ──────────────────────────────────────────────────────────────────

enum PayrollStatus {
  draft
  approved
  paid
}

model PayrollRun {
  id          String        @id @default(cuid())
  tenantId    String
  periodStart DateTime
  periodEnd   DateTime
  status      PayrollStatus @default(draft)
  totalGross  Float         @default(0)
  notes       String?
  createdById String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("PayrollCreatedBy", fields: [createdById], references: [id])
  entries   PayrollEntry[]

  @@index([tenantId])
  @@map("payroll_runs")
}

model PayrollEntry {
  id            String @id @default(cuid())
  payrollRunId  String
  userId        String
  regularHours  Float  @default(0)
  overtimeHours Float  @default(0)
  payRate       Float  @default(0)
  payType       String @default("hourly")
  grossPay      Float  @default(0)
  notes         String?

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@map("payroll_entries")
}

// ─── Compensation ─────────────────────────────────────────────────────────────

model PayComponent {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  type          String   // hourly|salary|commission_flat|commission_pct|commission_tiered|bonus_milestone|draw|revenue_share
  label         String?
  config        Json     @default("{}")
  effectiveDate DateTime @default(now())
  endDate       DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("pay_components")
}

model CommissionEntry {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  crmJobId       String
  payComponentId String?
  creditPct      Decimal  @db.Decimal(5, 2)
  jobValue       Decimal  @db.Decimal(10, 2)
  amount         Decimal  @db.Decimal(10, 2)
  payType        String
  status         String   @default("pending") // pending | finalized
  payRunId       String?
  note           String?
  createdAt      DateTime @default(now())

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id])
  crmJob         CRMJob   @relation(fields: [crmJobId], references: [id])

  @@index([tenantId, userId])
  @@index([tenantId, crmJobId])
  @@map("commission_entries")
}

model SalesTarget {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  targetAmount Decimal  @db.Decimal(10, 2)
  period       String   // monthly | quarterly
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@map("sales_targets")
}

// ─── Property Management Suite (Phase 2) ─────────────────────────────────────

enum PropertyType {
  residential
  commercial
  multi_family
  hoa
  short_term_rental
}

enum LeaseStatus {
  draft
  active
  expired
  terminated
  renewed
}

enum RentLedgerType {
  charge
  payment
  credit
  late_fee
  deposit
  refund
}

enum RentLedgerStatus {
  pending
  paid
  overdue
  waived
}

model Property {
  id              String       @id @default(cuid())
  tenantId        String
  name            String
  type            PropertyType @default(residential)
  street          String
  city            String
  state           String
  zip             String
  country         String       @default("US")
  lat             Float?
  lng             Float?
  totalUnits      Int          @default(1)
  yearBuilt       Int?
  notes           String?
  isArchived      Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  units           Unit[]
  expenses        Expense[]
  ownerContacts   OwnerContact[]

  @@index([tenantId])
  @@map("properties")
}

model Unit {
  id              String   @id @default(cuid())
  propertyId      String
  unitNumber      String
  bedrooms        Float    @default(0)
  bathrooms       Float    @default(0)
  sqft            Int?
  marketRent      Decimal? @db.Decimal(10, 2)
  isAvailable     Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases          Lease[]
  listings        RentalListing[]

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@map("units")
}

model PMTenant {
  id                String   @id @default(cuid())
  tenantId          String   // FSP tenant, not rental tenant
  firstName         String
  lastName          String
  email             String?
  phone             String?
  emergencyName     String?
  emergencyPhone    String?
  notes             String?
  isArchived        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  fspTenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leases            Lease[]

  @@index([tenantId])
  @@map("pm_tenants")
}

model Lease {
  id              String      @id @default(cuid())
  unitId          String
  pmTenantId      String
  status          LeaseStatus @default(active)
  startDate       DateTime
  endDate         DateTime?
  rentAmount      Decimal     @db.Decimal(10, 2)
  depositAmount   Decimal     @default(0) @db.Decimal(10, 2)
  depositPaid     Boolean     @default(false)
  lateFeePct      Decimal?    @db.Decimal(5, 2)
  lateFeeGrace    Int?        // days before late fee kicks in
  notes           String?
  documentUrl     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  unit            Unit        @relation(fields: [unitId], references: [id])
  pmTenant        PMTenant    @relation(fields: [pmTenantId], references: [id])
  ledgerEntries   RentLedger[]

  @@index([unitId])
  @@index([pmTenantId])
  @@map("leases")
}

model RentLedger {
  id          String            @id @default(cuid())
  leaseId     String
  type        RentLedgerType
  status      RentLedgerStatus  @default(pending)
  amount      Decimal           @db.Decimal(10, 2)
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime          @default(now())

  lease       Lease             @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@map("rent_ledger")
}

model Expense {
  id          String   @id @default(cuid())
  propertyId  String
  category    String   // maintenance | utilities | insurance | taxes | management | other
  vendor      String?
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @db.Date
  description String?
  receiptUrl  String?
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("expenses")
}

model OwnerContact {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  email       String?
  phone       String?
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("owner_contacts")
}

model RentalListing {
  id            String   @id @default(cuid())
  unitId        String
  listingPrice  Decimal  @db.Decimal(10, 2)
  availableFrom DateTime
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  unit          Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  applications  RentalApplication[]

  @@index([unitId])
  @@map("rental_listings")
}

model RentalApplication {
  id            String   @id @default(cuid())
  listingId     String
  firstName     String
  lastName      String
  email         String
  phone         String?
  currentAddress String?
  employer      String?
  monthlyIncome Decimal? @db.Decimal(10, 2)
  creditScore   Int?
  message       String?
  status        String   @default("pending") // pending | approved | rejected | withdrawn
  appliedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listing       RentalListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("rental_applications")
}

// ─── FieldOps Connect ─────────────────────────────────────────────────────────

enum ConnectPlan {
  none
  starter
  growth
  pro
  enterprise
}

model PortalConfig {
  id                  String      @id @default(cuid())
  tenantId            String      @unique
  connectPlan         ConnectPlan @default(none)
  isEnabled           Boolean     @default(false)

  // Branding
  portalName          String      @default("Customer Portal")
  logoUrl             String?
  primaryColor        String      @default("#2563eb")
  customDomain        String?

  // Feature flags
  enableBilling       Boolean     @default(true)
  enableWorkRequests  Boolean     @default(true)
  enableMessaging     Boolean     @default(true)
  enableDocuments     Boolean     @default(false)

  // Auth settings
  allowMagicLink      Boolean     @default(true)
  allowSmsOtp         Boolean     @default(false)

  // Notification settings
  notifyOnJobUpdate   Boolean     @default(true)
  notifyOnInvoice     Boolean     @default(true)
  notifyOnMessage     Boolean     @default(true)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("portal_configs")
}

model PortalUser {
  id              String    @id @default(cuid())
  tenantId        String
  customerId      String?
  email           String
  phone           String?
  displayName     String?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sessions        PortalSession[]
  workRequests    PortalWorkRequest[]
  messages        PortalMessage[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("portal_users")
}

model PortalSession {
  id            String    @id @default(cuid())
  portalUserId  String
  token         String    @unique @default(cuid())
  type          String    // magic_link | otp | session
  otp           String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  portalUser    PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)

  @@index([portalUserId])
  @@index([token])
  @@map("portal_sessions")
}

model PortalWorkRequest {
  id             String    @id @default(cuid())
  tenantId       String
  portalUserId   String
  crmJobId       String?
  title          String
  description    String
  serviceAddress String?
  category       String?
  urgency        String    @default("normal") // low | normal | high | emergency
  status         String    @default("submitted") // submitted | reviewing | scheduled | in_progress | completed | cancelled
  photoUrls      String[]
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portalUser     PortalUser @relation(fields: [portalUserId], references: [id])

  @@index([tenantId, status])
  @@index([portalUserId])
  @@map("portal_work_requests")
}

model PortalMessage {
  id             String    @id @default(cuid())
  tenantId       String
  portalUserId   String
  fromPortal     Boolean   @default(true) // true = from customer, false = from team
  senderName     String?
  body           String
  isRead         Boolean   @default(false)
  createdAt      DateTime  @default(now())

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portalUser     PortalUser @relation(fields: [portalUserId], references: [id])

  @@index([tenantId, portalUserId])
  @@map("portal_messages")
}

model TrainingResource {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  audience      String   @default("all") // all | technician | sales
  targetUserIds String[] @default([])    // when non-empty, only these user IDs can see it
  fileUrl       String?
  fileType      String?  // pdf | video | doc | link
  content       String?  // rich text / AI-tailored script content
  createdById   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("TrainingCreated", fields: [createdById], references: [id])

  @@index([tenantId, audience])
  @@map("training_resources")
}

model TrainingUserProgress {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String    @unique
  sectionsRead   String[]  @default([])
  exercisesDone  String[]  @default([])
  rolePlayCount  Int       @default(0)
  currentStreak  Int       @default(0)
  lastActivityAt DateTime?
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("training_user_progress")
}

model RolePlaySession {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  scenario   String
  difficulty String
  objection  String?
  transcript Json
  debrief    String?
  rating     String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@map("role_play_sessions")
}

model TrainingExerciseAnswer {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  exerciseId String
  answer     String
  aiFeedback String?
  status     String   @default("in_progress")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, exerciseId])
  @@index([tenantId, userId])
  @@map("training_exercise_answers")
}
